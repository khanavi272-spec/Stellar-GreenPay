PORT=4000
NODE_ENV=development
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ALLOWED_ORIGINS=https://greenpay.app,https://www.greenpay.app,https://stellar-greenpay.app,https://www.stellar-greenpay.app,http://localhost:3000,http://127.0.0.1:3000
CONTRACT_ID=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/greenpay

# Transactional email — get a free API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=GreenPay <updates@yourdomain.com>
APP_URL=http://localhost:3000

# JWT secret for admin authentication (generate with: openssl rand -hex 32)
JWT_SECRET=

# Admin login credentials (used by POST /api/admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
